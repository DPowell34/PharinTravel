# Notion internal integration secret (create at https://www.notion.so/my-integrations
# and share your "CRM" page with it)
NOTION_API_KEY=secret_xxx

# Data source (database) IDs for the Pharin's Travel CRM workspace
NOTION_CLIENTS_DB_ID=47b195ae-30b6-4ae3-84f1-0cc839851d92
NOTION_TRIPS_DB_ID=aa38c176-5800-4a96-98ec-7801dcf140b0
NOTION_SUPPLIERS_DB_ID=cb1dd0a9-74e0-40cd-87bd-efb295dbd984
NOTION_ACTIVITIES_DB_ID=fa043a0c-0535-4c8b-99f1-a99b50afdb49

# Shared secret checked on every inbound TravelJoy webhook (Zapier -> this server).
WEBHOOK_SECRET=change-me-to-something-random

# Shared secret checked on the read-only /api/* endpoints the dashboard calls.
DASHBOARD_API_KEY=change-me-too

# The "Catch Hook" URL from your outbound Zap (Catch Hook -> Create/Update Trip in TravelJoy).
ZAPIER_OUTBOUND_CATCH_URL=https://hooks.zapier.com/hooks/catch/xxxx/xxxx/

PORT=3000
